DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APP_ENV=production
# Troque pela URL canonica exata do frontend na Vercel (sem barra no final).
CORS_ORIGINS=https://seu-projeto.vercel.app
# Permite deployments de preview da Vercel. Localhost e adicionado pelo app apenas em development.
CORS_ORIGIN_REGEX=^https://[a-z0-9-]+\.vercel\.app$

